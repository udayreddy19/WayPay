# ============================================
# WayPay Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Database (PostgreSQL) ---
POSTGRES_DB=waypay
POSTGRES_USER=waypay
POSTGRES_PASSWORD=waypay_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=waypay_redis

# --- pgAdmin ---
PGADMIN_EMAIL=admin@waypay.in
PGADMIN_PASSWORD=admin

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- Stripe ---
STRIPE_API_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=inr

# --- Clerk (Authentication) ---
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# --- Resend (Email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@waypay.in

# --- PostHog (Analytics) ---
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Inngest (Background Jobs) ---
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# --- Application ---
APP_NAME=WayPay
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
APP_ENCRYPTION_KEY=your-32-char-encryption-key-here

# --- JWT ---
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# --- Sentry (Monitoring) ---
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
